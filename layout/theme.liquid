<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ page_title }}</title>
    {{ content_for_header }}
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS (CDN for instant Shopify compatibility) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              zonura: {
                navy: "{{ settings.color_primary | default: '#0E1E2E' }}",
                sand: "{{ settings.color_background | default: '#F4F1ED' }}",
                gold: "{{ settings.color_accent | default: '#C9A637' }}",
              }
            },
            fontFamily: {
              sans: ["Inter", "sans-serif"],
              serif: ["Playfair Display", "serif"]
            },
            borderRadius: {
              premium: "14px"
            }
          }
        }
      }
    </script>
    
    <style>
      body {
        background-color: #ffffff;
        color: #0E1E2E;
      }
      .hide-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="antialiased min-h-screen flex flex-col font-sans">
    {% section 'header' %}
    
    <main id="MainContent" class="flex-grow focus:outline-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    
    {% section 'footer' %}

    <!-- Global Cart Drawer -->
    <div id="cart-overlay" class="fixed inset-0 bg-zonura-navy/50 backdrop-blur-sm z-[80] opacity-0 pointer-events-none transition-opacity duration-300"></div>
    <div id="cart-drawer" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-white z-[90] transform translate-x-full transition-transform duration-300 shadow-2xl flex flex-col">
      <div class="p-6 border-b border-zonura-navy/10 flex justify-between items-center bg-zonura-sand/20">
        <span class="font-serif text-2xl font-bold tracking-tight text-zonura-navy">Your Bag</span>
        <button id="cart-close" class="p-2 text-zonura-navy focus:outline-none hover:rotate-90 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      
      <div id="cart-items" class="flex-1 overflow-y-auto p-6">
        <!-- JavaScript populates items here -->
        <div class="animate-pulse flex gap-4 items-center py-6">
          <div class="w-20 h-24 bg-zonura-sand/50 rounded-md"></div>
          <div class="flex-1 space-y-3">
            <div class="h-4 bg-zonura-sand/50 rounded w-3/4"></div>
            <div class="h-3 bg-zonura-sand/50 rounded w-1/2"></div>
          </div>
        </div>
      </div>
      
      <div class="p-6 border-t border-zonura-navy/10 bg-white">
        <div class="flex justify-between items-center mb-6">
          <span class="font-sans font-bold text-zonura-navy uppercase tracking-widest text-sm">Subtotal</span>
          <span id="cart-total" class="font-serif text-2xl font-bold text-zonura-navy">$0.00</span>
        </div>
        <p class="font-sans text-xs text-zonura-navy/60 mb-6 text-center">Shipping & taxes calculated at checkout.</p>
        <a href="{{ routes.cart_url }}" class="block w-full py-4 text-center rounded-premium bg-zonura-navy text-zonura-sand font-bold font-sans text-sm tracking-widest uppercase hover:bg-zonura-navy/90 transition-colors shadow-lg shadow-zonura-navy/20">
          PROCEED TO CHECKOUT
        </a>
      </div>
    </div>

    <!-- Theme Interactive JS -->
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
