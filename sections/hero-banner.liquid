<div class="relative w-full h-[600px] bg-zonura-navy overflow-hidden">
  {% if section.settings.image != blank %}
    <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" class="absolute inset-0 w-full h-full object-cover opacity-70" />
  {% else %}
    <img src="https://images.unsplash.com/photo-1615397323281-197282717088?q=80&w=2000&auto=format&fit=crop" alt="Hero Banner" class="absolute inset-0 w-full h-full object-cover opacity-70" />
  {% endif %}
  <div class="absolute inset-0 bg-gradient-to-t from-zonura-navy/80 to-transparent"></div>
  <div class="relative h-full flex flex-col justify-end px-8 md:px-16 pb-16 max-w-[1600px] mx-auto">
    <h1 class="font-serif text-5xl md:text-7xl text-zonura-sand mb-4 leading-tight max-w-3xl">{{ section.settings.heading }}</h1>
    <p class="font-sans text-lg md:text-xl text-zonura-sand/80 max-w-xl mb-8 font-light">{{ section.settings.subheading }}</p>
    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="w-fit bg-zonura-sand text-zonura-navy px-8 py-4 rounded-premium font-sans font-bold text-sm tracking-wide hover:bg-white transition-colors">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>
{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Awaken your aura."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover botanical essences crafted to restore balance and elevate your daily ritual."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "EXPLORE COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
