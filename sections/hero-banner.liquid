{% assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 %}

<div class="relative w-full h-[500px] md:h-[600px] lg:h-[700px] bg-zonura-navy overflow-hidden">
  
  <!-- Desktop Image -->
  {% if section.settings.image_desktop != blank %}
    <img src="{{ section.settings.image_desktop | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" class="absolute inset-0 w-full h-full object-cover {% if section.settings.image_mobile != blank %}hidden md:block{% endif %}" />
  {% else %}
    <img src="https://images.unsplash.com/photo-1615397323281-197282717088?q=80&w=2000&auto=format&fit=crop" alt="Hero Banner" class="absolute inset-0 w-full h-full object-cover {% if section.settings.image_mobile != blank %}hidden md:block{% endif %}" />
  {% endif %}

  <!-- Mobile Image -->
  {% if section.settings.image_mobile != blank %}
    <img src="{{ section.settings.image_mobile | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" class="absolute inset-0 w-full h-full object-cover md:hidden" />
  {% endif %}

  <!-- Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-zonura-navy to-transparent" style="opacity: {{ overlay_opacity }};"></div>
  
  <!-- Content -->
  <div class="relative h-full flex flex-col md:flex-row items-start md:items-end justify-between px-6 md:px-16 pb-12 md:pb-20 pt-32 max-w-[1600px] mx-auto gap-8 md:gap-12">
    
    <!-- Text Content -->
    <div class="flex flex-col w-full md:w-auto {{ section.settings.text_alignment }} max-w-3xl justify-end h-full">
      <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl text-zonura-sand mb-4 leading-tight">{{ section.settings.heading }}</h1>
      <p class="font-sans text-base md:text-xl text-zonura-sand/80 max-w-xl mb-8 font-light leading-relaxed">{{ section.settings.subheading }}</p>
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="w-fit bg-zonura-sand text-zonura-navy px-8 py-4 rounded-premium font-sans font-bold text-sm tracking-wide hover:bg-white transition-colors text-center inline-block">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <!-- Featured Product Card -->
    {% if section.settings.featured_product != blank %}
      {% assign fp = section.settings.featured_product %}
      <a href="{{ fp.url }}" class="hidden md:flex flex-col group w-full max-w-[280px] lg:max-w-[320px] bg-white/10 backdrop-blur-md border border-white/20 rounded-premium p-4 shadow-2xl hover:bg-white/20 transition-all shrink-0">
        <div class="relative aspect-[4/5] rounded-[10px] overflow-hidden mb-4">
          <img src="{{ fp.featured_image | image_url: width: 600 }}" alt="{{ fp.title | escape }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          <div class="absolute top-3 left-3 bg-zonura-gold text-zonura-navy text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full">Featured</div>
        </div>
        <h3 class="font-sans font-bold text-zonura-sand text-sm lg:text-base mb-1 truncate">{{ fp.title }}</h3>
        <div class="flex items-center justify-between">
          <p class="font-serif text-zonura-sand/90 text-sm lg:text-base">{{ fp.price | money }}</p>
          <span class="w-8 h-8 rounded-full bg-zonura-sand text-zonura-navy flex items-center justify-center group-hover:bg-zonura-gold transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </span>
        </div>
      </a>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image (Optional)",
      "info": "If provided, this image will show on mobile devices instead of the desktop image."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Gradient Overlay Opacity",
      "default": 80
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "text-left items-start", "label": "Left" },
        { "value": "text-center items-center", "label": "Center" },
        { "value": "text-right items-end", "label": "Right" }
      ],
      "default": "text-left items-start"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Awaken your aura."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover botanical essences crafted to restore balance and elevate your daily ritual."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "EXPLORE COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Shoppable Featured Product"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product",
      "info": "Select a product to display as a floating glassmorphic card on desktop."
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
