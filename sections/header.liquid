<div class="bg-white px-4 py-3 flex items-center justify-between gap-4 lg:gap-8 border-b border-zonura-navy/5 sticky top-0 z-50">
  <a href="{{ routes.root_url }}" class="flex items-center shrink-0">
    <span class="font-serif text-3xl font-bold tracking-tight text-zonura-navy">{{ shop.name }}</span>
  </a>
  
  <div class="flex-1 max-w-2xl hidden md:block">
    <form action="{{ routes.search_url }}" method="get" class="relative w-full">
      <svg class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-zonura-navy/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      <input type="text" name="q" placeholder="Search for serums, oils, wellness..." class="w-full bg-zonura-sand/50 rounded-full py-3 px-6 pl-12 text-sm font-sans text-zonura-navy focus:outline-none focus:ring-2 focus:ring-zonura-navy/20 transition-all placeholder:text-zonura-navy/40" />
    </form>
  </div>

  <div class="flex items-center gap-6 shrink-0">
    <a href="{{ routes.account_url }}" class="flex flex-col items-center gap-1 group">
      <svg class="w-6 h-6 text-zonura-navy/80 group-hover:text-zonura-navy transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
      <span class="font-sans text-[10px] uppercase tracking-wider font-bold text-zonura-navy/60 group-hover:text-zonura-navy transition-colors">Profile</span>
    </a>
    
    <a href="#" class="flex flex-col items-center gap-1 group">
      <svg class="w-6 h-6 text-zonura-navy/80 group-hover:text-zonura-navy transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
      <span class="font-sans text-[10px] uppercase tracking-wider font-bold text-zonura-navy/60 group-hover:text-zonura-navy transition-colors">Wishlist</span>
    </a>

    <a href="{{ routes.cart_url }}" class="flex flex-col items-center gap-1 group relative">
      <div class="relative">
        <svg class="w-6 h-6 text-zonura-navy/80 group-hover:text-zonura-navy transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
        {% if cart.item_count > 0 %}
          <span class="absolute -top-1 -right-1 bg-zonura-gold text-zonura-navy text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center">{{ cart.item_count }}</span>
        {% endif %}
      </div>
      <span class="font-sans text-[10px] uppercase tracking-wider font-bold text-zonura-navy/60 group-hover:text-zonura-navy transition-colors">Bag</span>
    </a>
  </div>
</div>
