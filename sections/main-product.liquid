<div class="w-full max-w-[1600px] mx-auto px-4 md:px-8 py-8 md:py-12">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
    
    <!-- Left Column: Myntra-Style 2x2 Image Grid -->
    <div class="lg:col-span-7">
      <div class="grid grid-cols-2 gap-2 md:gap-4">
        {% for image in product.images %}
          <div class="relative aspect-[3/4] bg-zonura-sand/20 {% if forloop.first %}col-span-2 aspect-[4/5]{% endif %}">
            <img src="{{ image.src | img_url: '1000x' }}" alt="{{ image.alt | escape }}" class="w-full h-full object-cover" />
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Right Column: Sticky Product Info -->
    <div class="lg:col-span-5 relative">
      <div class="sticky top-28 flex flex-col">
        
        <h1 class="font-serif text-3xl lg:text-4xl text-zonura-navy leading-tight mb-2">
          {{ product.title }}
        </h1>
        
        <p class="font-sans text-sm tracking-[0.2em] text-zonura-gold uppercase font-bold mb-4">
          ZONURA Exclusive
        </p>

        <div class="h-[1px] w-full bg-zonura-navy/10 mb-6"></div>

        <div class="flex items-end gap-3 mb-2">
          <span class="font-serif text-3xl font-bold text-zonura-navy">
            {{ product.price | money }}
          </span>
          {% if product.compare_at_price > product.price %}
            <span class="font-sans text-sm text-zonura-navy/50 line-through mb-1">
              {{ product.compare_at_price | money }}
            </span>
          {% endif %}
        </div>
        <p class="font-sans text-xs text-green-700 font-bold mb-6">inclusive of all taxes</p>

        <div class="font-sans text-sm text-zonura-navy/80 leading-relaxed font-light mb-2 prose max-w-none">
          {{ product.description }}
        </div>

        <!-- Buy Box Form -->
        <div class="flex flex-col gap-6 mt-8">
          {% form 'product', product, class: 'flex flex-col gap-3' %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            
            <div class="flex items-center gap-4">
              <button type="submit" name="add" class="flex-1 py-4 flex items-center justify-center gap-2 rounded-premium bg-zonura-navy text-zonura-sand font-bold font-sans text-sm tracking-wide hover:bg-zonura-navy/90 transition-colors {% unless product.available %}opacity-50 cursor-not-allowed{% endunless %}" {% unless product.available %}disabled{% endunless %}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                {% if product.available %}ADD TO BAG{% else %}SOLD OUT{% endif %}
              </button>
              
              <button type="button" class="wishlist-btn flex-1 py-4 flex items-center justify-center gap-2 rounded-premium border-2 border-zonura-navy/10 text-zonura-navy font-bold font-sans text-sm tracking-wide hover:border-zonura-navy transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                WISHLIST
              </button>
            </div>
          {% endform %}
        </div>

        <div class="mt-8 border-t border-b border-zonura-navy/10">
          <div class="w-full py-5 flex items-center justify-between group cursor-pointer">
            <span class="font-sans tracking-widest text-sm uppercase text-zonura-navy font-bold">The Details</span>
          </div>
          <div class="pb-6">
            <p class="font-sans text-zonura-navy/80 leading-relaxed font-light text-sm">
              Wild-harvested ingredients designed to enhance your natural aura and provide deep hydration.
            </p>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Product Layout",
  "presets": [{"name": "Main Product"}]
}
{% endschema %}
